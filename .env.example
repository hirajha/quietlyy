# ═══════════════════════════════════════════════════════════════
# Quietlyy — Environment Variables
# For local testing only. For GitHub Actions, use GitHub Secrets.
# ═══════════════════════════════════════════════════════════════

# === AI Script Generation (4-layer fallback) ===
GROQ_API_KEY=your_groq_key          # Layer 1: Free 500K tokens/day
CEREBRAS_API_KEY=your_cerebras_key   # Layer 2: Free 1M tokens/day
GEMINI_API_KEY=your_gemini_key       # Layer 3: Free 250 req/day
# Layer 4: Template fallback (no API needed)

# === Image Generation (4-layer fallback) ===
# GEMINI_API_KEY (shared above)      # Layer 1: AI image gen
PEXELS_API_KEY=your_pexels_key       # Layer 2: Stock photos
PIXABAY_API_KEY=your_pixabay_key     # Layer 3: Stock photos (optional)
# Layer 4: Gradient fallback (no API needed)

# === Audio (3-layer fallback) ===
# Layer 1-2: edge-tts (free, no key needed, multiple voice fallbacks)
# Layer 3: gTTS (Google Translate TTS, free, no key needed)

# === Facebook Page Posting ===
FB_PAGE_ID=your_facebook_page_id
FB_PAGE_ACCESS_TOKEN=your_never_expiring_page_token

# === Optional: Override defaults ===
# VOICE=en-US-GuyNeural
# PITCH=-30Hz
# RATE=-18%
